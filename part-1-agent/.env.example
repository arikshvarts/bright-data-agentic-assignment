BRIGHT_DATA_API_TOKEN=

# Use either Anthropic or OpenAI. Anthropic is preferred when both are present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides
REGION=il
MAX_SOURCES=10
MAX_TRENDS=5
MCP_REQUEST_TIMEOUT_MS=180000

# Structured TikTok posts/comments through the Bright Data MCP social group.
# The agent falls back to Rapid tools if the account cannot use these tools.
BRIGHT_DATA_MCP_GROUPS=social
BRIGHT_DATA_SOCIAL_ENRICHMENT=true
SOCIAL_ENRICH_MAX_POSTS=1
SOCIAL_ENRICH_MAX_COMMENTS=0
