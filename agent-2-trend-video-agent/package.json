{
  "name": "trend-to-video-agent",
  "version": "1.0.0",
  "description": "A Bright Data MCP-powered trend-to-video agent for location-aware social video concepts.",
  "type": "module",
  "private": true,
  "scripts": {
    "demo": "tsx src/cli.ts",
    "demo:live": "tsx src/cli.ts --profile-file ./samples/local-cafe.json --max-sources 6 --max-trends 4",
    "demo:deep-social": "tsx src/cli.ts --profile-file ./samples/local-cafe.json --max-sources 6 --max-trends 4 --social-posts 2 --social-comments 1",
    "demo:fitness": "tsx src/cli.ts --profile-file ./samples/boutique-fitness-coach.json --max-sources 6 --max-trends 4",
    "demo:b2b": "tsx src/cli.ts --profile-file ./samples/b2b-ai-bookkeeping.json --max-sources 6 --max-trends 4",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "openai": "^4.104.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
